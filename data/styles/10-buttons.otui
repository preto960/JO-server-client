Button < UIButton
  font: verdana-11px-antialised
  color: #D0D0E0
  size: 43 20
  text-offset: 0 2
  background-color: #2E2E4A
  border-width: 1
  border-color: #3E3E5A
  border-radius: 4
  padding: 10
  opacity: 1.0

  $hover !disabled:
    background-color: #3A3A56
    border-color: #4A4A68

  $pressed:
    background-color: #444462
    text-offset: 1 1

  $on:
    background-color: #444462
    text-offset: 1 1

  $checked:
    background-color: #444462
    text-offset: 1 1

  $disabled:
    color: #D0D0E088
    opacity: 0.8
    change-cursor-image: false

TabButton < UIButton
  size: 22 23
  background-color: #252540
  border-width: 1
  border-color: #2E2E48
  border-radius: 4
  text-offset: 0 1
  icon-color: #A0A0B8
  color: #A0A0B8
  change-cursor-image: true
  cursor: pointer

  $hover !on:
    background-color: #2E2E4A
    color: #D0D0E0

  $disabled:
    background-color: #1E1E2E
    color: #A0A0B866
    icon-color: #A0A0B8
    change-cursor-image: false

  $on:
    background-color: #3A3A58
    color: #D0D0E0

NextButton < UIButton
  size: 12 21
  background-color: #252540
  border-width: 1
  border-color: #2E2E48
  border-radius: 3
  image-color: #A0A0B8
  text-offset: 0 1
  change-cursor-image: true
  cursor: pointer

  $hover !disabled:
    background-color: #2E2E4A

  $pressed:
    background-color: #444462

  $disabled:
    background-color: #1E1E2E
    change-cursor-image: false

