QtButton < UIButton
  font: verdana-11px-antialised
  size: 106 23
  text-offset: 0 0
  background-color: #2E2E4A
  border-width: 1
  border-color: #3E3E5A
  border-radius: 5
  padding: 5 10 5 10
  opacity: 1.0
  color: #C0C0D0

  $hover !disabled:
    background-color: #3A3A56
    border-color: #4A4A68

  $pressed:
    background-color: #444462
    text-offset: 1 1

  $disabled:
    color: #C0C0D088
    opacity: 0.8

BigPremiumButton < UIButton
  size: 128 37
  image-source: /images/ui/getpremium
  image-clip: 0 0 128 37
  image-border: 3
  $pressed:
    image-clip: 0 37 128 37
  $!on:
    image-clip: 0 74 128 37
  $disabled:
    color: #dfdfdf88
    opacity: 0.8

MiniPremiumButton < UIButton
  size: 26 22
  image-source: /images/ui/miniStoreIcon
  image-clip: 0 0 26 22
  $pressed:
    image-clip: 0 22 26 22
