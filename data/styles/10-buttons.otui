PreviousConsoleQtButton < UIButton
  size: 18 16
  image-source: /images/ui/console_direction_button
  image-clip: 36 0 18 16

  $pressed:
    image-clip: 18 0 18 16

  $pressed disabled:
    image-clip: 0 0 18 16

  $disabled:
    image-clip: 54 0 18 16

