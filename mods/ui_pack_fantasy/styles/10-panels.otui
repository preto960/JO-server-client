  UIWidget
    anchors.right: parent.right
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    background-color: #D4A017
    margin-top: -4
    margin-right: -4
    margin-bottom: -4
    width: 2

  UIWidget
    anchors.top: parent.top
    anchors.left: parent.left
    background-color: #6B4A22
    margin-top: -4
    margin-left: -4
    size: 2 2

  UIWidget
    anchors.top: parent.top
    anchors.right: parent.right
    background-color: #6B4A22
    margin-top: -4
    margin-right: -4
    size: 2 2

  UIWidget
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    background-color: #D4A017
    margin-bottom: -4
    margin-left: -4
    size: 2 2

  UIWidget
    anchors.bottom: parent.bottom
    anchors.right: parent.left
    background-color: #D4A017
    margin-bottom: -4
    margin-right: -4
    size: 2 2
