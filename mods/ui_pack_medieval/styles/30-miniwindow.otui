FloatingInputWindow < UIGroup
  background-color: #1A1E24
  border-color: #4A5568
  border-width: 1
  padding: 2
  size: 200 30

  UITextEdit#textEdit
    background-color: #111827
    color: #D1D5DB
    border-color: #374151
    border-width: 1
    font: terminus-medium-12px
    padding: 4 6
    anchors.fill: parent
    text-offset-x: 4
    text-offset-y: 2
    selection-color: #4A556866
    selection-background-color: #4A5568

BorderlessGameWindow < UIGroup
  background-color: transparent
  border-color: transparent
  border-width: 0
  size: 200 200
  &dragable: true

  UILabel#dragHeader
    background-color: #2D374899
    color: #D1D5DB
    font: terminus-medium-11px
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    height: 18
    padding-left: 4
    padding-right: 4
    text-auto-resize: true
    text-margin-bottom: 1
