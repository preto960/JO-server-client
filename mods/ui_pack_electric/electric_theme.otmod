Module
  name: ui_pack_electric
  description: Electric Blue UI Theme - Neon cyberpunk blue on deep black
  author: JO Dev
  version: 1.0
  autoLoad: true
  loadLater: true
  dependOnClient: true
  sandboxed: false

  dependencies:
    - client_styles

  @onLoad: |
    if g_modules.getModule('ui_pack_fantasy') and g_modules.getModule('ui_pack_fantasy'):isLoaded() then
      g_logger.warning('[Electric Theme] Fantasy theme is already active, skipping electric theme.')
      return
    end
    if g_modules.getModule('ui_pack_medieval') and g_modules.getModule('ui_pack_medieval'):isLoaded() then
      g_logger.warning('[Electric Theme] Medieval theme is already active, skipping electric theme.')
      return
    end
    g_logger.info('[Electric Theme] Loading Electric Blue UI Pack...')
    importStyle '/ui_pack_electric/styles/10-windows.otui'
    importStyle '/ui_pack_electric/styles/10-buttons.otui'
    importStyle '/ui_pack_electric/styles/10-panels.otui'
    importStyle '/ui_pack_electric/styles/10-labels.otui'
    importStyle '/ui_pack_electric/styles/10-checkboxes.otui'
    importStyle '/ui_pack_electric/styles/10-textedits.otui'
    importStyle '/ui_pack_electric/styles/10-separators.otui'
    importStyle '/ui_pack_electric/styles/10-progressbars.otui'
    importStyle '/ui_pack_electric/styles/10-scrollbars.otui'
    importStyle '/ui_pack_electric/styles/20-tabbars.otui'
    importStyle '/ui_pack_electric/styles/20-popupmenus.otui'
    importStyle '/ui_pack_electric/styles/20-topmenu.otui'
    importStyle '/ui_pack_electric/styles/30-miniwindow.otui'
    importStyle '/ui_pack_electric/styles/30-messageboxes.otui'
    importStyle '/ui_pack_electric/styles/15-login.otui'
    g_logger.info('[Electric Theme] Electric Blue UI Pack loaded successfully!')
