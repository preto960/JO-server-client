UIWidget
  id: chatCustomWindow
  visible: false
  focusable: true
  size: 560 380
  background-color: #1E1E2EDD
  border-width: 1
  border-color: #2A2A3EAA
  border-radius: 8
  @onEscape: modules.game_chat_custom.closeChatPopup()

  UIWidget
    id: chatTitleBar
    height: 32
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    background-color: #161626EE
    border-radius: 8

    Label
      !text: 'Chat'
      font: verdana-11px-rounded
      color: #D0D0D0
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter

    UIButton
      id: chatCloseButton
      !text: 'X'
      font: verdana-11px-rounded
      color: #666680
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
      width: 26
      height: 26
      margin-right: 8
      @onClick: modules.game_chat_custom.closeChatPopup()
      $hover:
        color: #AAAACC

  UIWidget
    id: chatTabBarSlot
    height: 28
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    background-color: #181830CC
    margin-top: 2

  UIWidget
    id: chatContentSlot
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: chatInputPanel.top
    margin: 2 2 2 2
    background-color: #14142ADD
    padding: 0

  UIWidget
    id: chatInputPanel
    height: 40
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin: 4 4 4 4
    background-color: #181830CC
    border-width: 1
    border-color: #2A2A40AA
    border-radius: 6

    UIWidget
      id: chatInputBox
      anchors.left: parent.left
      anchors.right: chatSendBtn.left
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      margin: 6 4 6 8
      background-color: #222238CC
      border-width: 1
      border-color: #2E2E48AA
      border-radius: 5

    TextEdit
      id: chatInput
      anchors.fill: prev
      margin: 2 4 2 4
      shift-navigation: true
      max-length: 255
      background-color: #222238CC
      color: #E0E0E0
      font: verdana-11px-antialised
      text-align: left
      text-vertical-alignment: center
      placeholder: "Escribe un mensaje..."
      placeholder-color: #4A4A60
      selection-color: #E0E0E0FF
      selection-background-color: #3A3A58
      border-width: 0
      image-source: none

    UIButton
      id: chatSendBtn
      !text: 'Enviar'
      font: verdana-11px-rounded
      color: #9999AA
      background-color: #222238CC
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
      width: 58
      height: 28
      margin-right: 8
      border-width: 1
      border-color: #2E2E48
      border-radius: 5
      @onClick: modules.game_chat_custom.sendChatMessage()
      $hover:
        background-color: #2A2A42CC
        color: #D0D0E0
      $pressed:
        background-color: #323250CC
