GameHeaderBar < UIWidget
  visible: false
  focusable: false
  height: 36
  background-color: #080810
  border-width-bottom: 2
  border-color-bottom: #00e5ff
  padding-left: 8
  padding-right: 8

  $on:
    background-color: #080810

HeaderBarButton < UIButton
  font: verdana-11px-rounded
  color: #6e7681
  anchors.top: parent.top
  anchors.bottom: parent.bottom
  margin-top: 5
  margin-bottom: 5
  padding-left: 14
  padding-right: 14
  border-width: 1
  border-color: #00e5ff18
  background-color: #0d1117
  border-radius: 2

  $hover:
    background-color: #0d1117
    border-color: #00e5ff50
    color: #00e5ff
    border-width-bottom: 2
    border-color-bottom: #00e5ff

  $pressed:
    background-color: #00e5ff0d
    border-color: #00e5ff
    color: #00e5ff

HeaderBarIconButton < UIButton
  size: 28 28
  image-color: #6e7681
  image-border: 4
  border-width: 1
  border-color: transparent
  border-radius: 2
  background-color: transparent
  icon-color: #6e7681

  $hover:
    border-color: #00e5ff40
    image-color: #00e5ff
    icon-color: #00e5ff

  $checked:
    image-color: #00e5ff
    icon-color: #00e5ff
    border-color: #00e5ff60

  $pressed:
    background-color: #00e5ff15
    image-color: #00e5ff
    icon-color: #00e5ff
    border-color: #00e5ff80